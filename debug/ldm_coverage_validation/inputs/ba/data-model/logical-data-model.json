    {
      "id": "ENT-004",
      "name": "LeaveRequest",
      "glossary_ref": "GLO-012",
      "description": "A formal request by an employee for a period of leave. The primary aggregate — owns the leave lifecycle state machine.",
      "owning_module": "leave-request",
      "attributes": [
        { "name": "id",              "type": "uuid",    "nullable": false, "constraints": ["PK"] },
        { "name": "employee_id",     "type": "uuid",    "nullable": false, "constraints": ["FK -> Employee.id"] },
