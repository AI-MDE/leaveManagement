        { "name": "start_date",      "type": "date",    "nullable": false },
        { "name": "end_date",        "type": "date",    "nullable": false },
        { "name": "total_days",      "type": "decimal", "nullable": false, "note": "Calculated at submission" },
        { "name": "reason",          "type": "string",  "nullable": true },
        { "name": "status",          "type": "enum",    "nullable": false, "values": ["PENDING", "APPROVED", "REJECTED", "CANCELLED"],
          "note": "PENDING→APPROVED|REJECTED|CANCELLED; APPROVED→CANCELLED|PENDING (on re-approval)" },
        { "name": "submitted_at",    "type": "datetime","nullable": false },
        { "name": "reviewed_at",     "type": "datetime","nullable": true },
        { "name": "reviewed_by",     "type": "uuid",    "nullable": true, "constraints": ["FK -> Employee.id"], "note": "Manager who acted" },
        { "name": "manager_comment", "type": "string",  "nullable": true },
        { "name": "version",         "type": "integer", "nullable": false, "default": 1, "note": "Incremented on each modification" },
        { "name": "created_at",      "type": "datetime","nullable": false },
        { "name": "updated_at",      "type": "datetime","nullable": false }
      ],
      "business_rules": [
        { "rule": "BR-001", "description": "Balance must cover total_days at submission (unless HR Admin override)" },
        { "rule": "BR-002", "description": "start_date must be at least advance_notice_days from submitted_at for the leave type" },
        { "rule": "BR-003", "description": "No overlap with other PENDING or APPROVED requests for the same employee" },
        { "rule": "BR-004", "description": "Cancellation of APPROVED request restores balance and notifies manager" },
        { "rule": "BR-005", "description": "Modification of APPROVED request resets status to PENDING (re-approval required)" }
      ],
      "relationships": [
        { "type": "belongs_to", "target": "Employee",        "cardinality": "many-to-one", "via": "employee_id",   "description": "Requesting employee" },
        { "type": "belongs_to", "target": "LeaveType",       "cardinality": "many-to-one", "via": "leave_type_id" },
        { "type": "belongs_to", "target": "Employee",        "cardinality": "many-to-one", "via": "reviewed_by",   "description": "Reviewing manager (nullable)" },
        { "type": "has_many",   "target": "LeaveAuditEntry", "cardinality": "one-to-many", "via": "leave_request_id" },
        { "type": "has_many",   "target": "Notification",    "cardinality": "one-to-many", "via": "leave_request_id" }
      ],
