            {
              "id": "integration-tests",
              "label": "Integration Tests",
              "docType": "source-code",
              "scan": {
                "dir": "$config.test.integration",
                "pattern": "$config.test.integrationPattern",
                "recursive": true,
                "groupBy": "module-folder",
                "sortBy": "filename"
              }
            }
          ]
        }
      ]
    }
