      "phase": "development",
      "icon": "code",
      "items": [
        {
          "id": "sample-data",
          "label": "Sample Data",
          "docType": "sample-data",
          "scan": {
            "dir": "$config.output.src/../output/sample-data",
            "pattern": ".*\\.json$",
            "labelFrom": "filename",
            "sortBy": "filename"
          }
        },
        {
          "id": "source-code",
          "label": "Source Code",
          "docType": "source-code",
          "scan": {
            "dir": "$config.output.src",
            "pattern": ".*\\.ts$",
            "recursive": true,
            "groupBy": "module-folder",
            "sortBy": "filename"
          }
        },
        {
          "id": "tests",
          "label": "Tests",
          "items": [
