            { "id": "schema-sql",   "label": "Schema DDL",   "docType": "sql",          "file": "$config.design.sql/schema.sql" },
            { "id": "schema-state", "label": "Schema State", "docType": "schema-state", "file": "$config.design.sql/schema-state.json" }
          ]
        }
      ]
    },
    {
      "id": "modules",
      "label": "Modules",
      "phase": "module_definition",
      "icon": "puzzle",
      "items": [
