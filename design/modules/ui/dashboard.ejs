<%- include('../layouts/header') %>

<div class="container mt-4">
    <h1>My Leave Dashboard</h1>
    <p class="text-muted"><%= purpose %></p>

    <!-- Balance Summary Cards (FR-015) -->
    <div class="row mb-4">
        <% balances.forEach(balance => { %>
            <div class="col-md-3">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h6 class="card-subtitle mb-2 text-muted"><%= balance.leaveTypeName %></h6>
                        <h2 class="card-title"><%= balance.availableDays %> <small>days</small></h2>
                        <p class="card-text small">Used: <%= balance.usedDays %> | Pending: <%= balance.pendingDays %></p>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>

    <!-- Active Requests (FR-015) -->
    <div class="card shadow-sm mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Active Requests</h5>
            <a href="/my-leave/new" class="btn btn-primary btn-sm">New Request</a>
        </div>
        <div class="card-body">
            <% if (activeRequests.length > 0) { %>
                <table class="table">
                    <thead>
                        <tr>
                            <th>Dates</th>
                            <th>Type</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% activeRequests.forEach(req => { %>
                            <tr>
                                <td><%= req.startDate %> to <%= req.endDate %></td>
                                <td><%= req.leaveTypeName %></td>
                                <td><span class="badge bg-info"><%= req.status %></span></td>
                                <td><a href="/my-leave/requests/<%= req.id %>">View</a></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } else { %>
                <p class="text-center py-4"><%= emptyState %></p>
            <% } %>
        </div>
    </div>
</div>

<%- include('../layouts/footer') %>