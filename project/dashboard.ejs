<%- include('../layouts/header') %>
<div class="container mt-4">
    <h1>My Leave Dashboard</h1>
    <div class="row mb-4">
        <% balances.forEach(balance => { %>
            <div class="col-md-3">
                <div class="card">
                    <div class="card-body">
                        <h6><%= balance.leaveTypeName %></h6>
                        <h2><%= balance.availableDays %> days</h2>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
    <div class="card">
        <div class="card-header">Active Requests</div>
        <div class="card-body">
            <% if (activeRequests.length > 0) { %>
                <!-- Table implementation -->
            <% } else { %>
                <p>No active requests.</p>
            <% } %>
        </div>
    </div>
</div>
<%- include('../layouts/footer') %>
