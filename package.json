{
  "name": "leave-management",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:all": "concurrently -k -n api,ui -c cyan,magenta \"npm run dev\" \"npm --prefix ui run dev\"",
    "reset-database": "node scripts/resetDatabase.js",
    "create-tables": "node scripts/createTables.js",
    "regenerate-seed-data": "node scripts/regenerateSeedData.js",
    "seed": "node scripts/loadSeedData.js",
    "db:init": "npm run reset-database && npm run create-tables && npm run seed",
    "test": "jest",
    "test:unit": "jest --testPathPattern=test/unit",
    "test:integration": "jest --testPathPattern=test/integration",
    "test:screenshots": "node scripts/takeScreenshots.js",
    "export:mkdocs": "node scripts/exportDocs.js --target=mkdocs",
    "export:confluence": "node scripts/exportDocs.js --target=confluence",
    "docs:serve": "mkdocs serve -f mkdocs/mkdocs.yml",
    "docs:build": "mkdocs build -f mkdocs/mkdocs.yml --clean"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "pg": "^8.12.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "concurrently": "^9.0.1",
    "ts-jest": "^29.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "@playwright/test": "^1.44.0",
    "mustache": "^4.2.0",
    "marked": "^12.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.ts"
    ],
    "setupFiles": [
      "./test/jest.setup.ts"
    ],
    "collectCoverage": false
  }
}
